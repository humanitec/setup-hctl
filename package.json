{
  "name": "setup-hctl",
  "version": "1.0.0",
  "author": "",
  "private": true,
  "description": "A GitHub action for installing the Humanitec hctl binary within a workflow.",
  "homepage": "https://github.com/humanitec/setup-hctl",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/humanitec/setup-hctl.git"
  },
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/humanitec/setup-hctl/issues"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "engines": {
    "node": ">=24"
  },
  "main": "dist/index.js",
  "scripts": {
    "bundle": "npm run format:write && npm run package",
    "format:write": "prettier --write **/*.ts",
    "format:check": "prettier --check **/*.ts",
    "lint": "npx eslint",
    "package": "esbuild src/index.ts --bundle --platform=node --target=node24 --outfile=dist/index.js",
    "test": "NODE_OPTIONS='--experimental-vm-modules' jest"
  },
  "jest": {
    "verbose": true,
    "clearMocks": true,
    "testEnvironment": "node",
    "extensionsToTreatAsEsm": [
      ".ts"
    ],
    "moduleFileExtensions": [
      "js",
      "ts"
    ],
    "testMatch": [
      "**/*.test.ts"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/dist/"
    ],
    "transform": {
      "^.+\\.ts$": [
        "ts-jest",
        {
          "useESM": true
        }
      ]
    }
  },
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@actions/github": "^9.0.0",
    "@actions/tool-cache": "^4.0.0",
    "semver": "^7.7.4"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "@types/semver": "^7.7.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.1",
    "esbuild": "^0.27.4",
    "eslint": "^9.39.4",
    "eslint-plugin-github": "^6.0.0",
    "eslint-plugin-jest": "^29.15.1",
    "eslint-plugin-jsonc": "^2.21.0",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^30.3.0",
    "prettier": "^3.8.1",
    "prettier-eslint": "^16.4.2",
    "ts-jest": "^29.4.9",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "minimatch@3": "3.1.5",
    "minimatch@9": "9.0.9"
  }
}
